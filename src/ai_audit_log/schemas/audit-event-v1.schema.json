        "session_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Session Id"
        }
      },
      "required": [
        "actor_id",
        "actor_type"
      ],
      "title": "Actor",
      "type": "object"
    },
